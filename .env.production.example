# ==============================================
# FEEDBACK PORTAL - ENVIRONMENT VARIABLES
# ==============================================

# MongoDB Connection String (REQUIRED)
# Get from: https://cloud.mongodb.com
# Create free cluster, then: Connect -> Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/feedbackdb?retryWrites=true&w=majority

# Server Configuration
PORT=3000
NODE_ENV=production

# Base URL (IMPORTANT for production)
# This is used to generate feedback links
# For local: http://localhost:3000
# For Render: https://your-app.onrender.com
BASE_URL=http://localhost:3000

# CORS Origins (comma-separated for production)
# Example: https://yourdomain.com,https://app.vercel.app
# For development, use *
ALLOWED_ORIGINS=*

# JWT Secret (change this in production!)
JWT_SECRET=change_this_to_a_random_string_in_production
